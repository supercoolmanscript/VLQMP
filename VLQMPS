local container = Instance.new("Frame", main)
container.Size = UDim2.new(1, -135, 1, -10); container.Position = UDim2.new(0, 130, 0, 5); container.BackgroundTransparency = 1

local pages, tabs = {}, {}
local function createTab(name)
    local b = Instance.new("TextButton", sidebar)
    b.Size = UDim2.new(1, 0, 0, 32); b.BackgroundTransparency = 1
    b.Text = name:upper(); b.TextColor3 = Color3.fromRGB(150, 120, 130); b.Font = Enum.Font.GothamBold; b.TextSize = 10
    local p = Instance.new("ScrollingFrame", container)
    p.Size = UDim2.new(1, 0, 1, 0); p.BackgroundTransparency = 1; p.Visible = false
    p.ScrollBarThickness = 2; p.ScrollBarImageColor3 = cfg.accent; p.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Instance.new("UIListLayout", p).Padding = UDim.new(0, 5)
    b.MouseButton1Click:Connect(function()
        for _, pg in pairs(pages) do pg.Visible = false end
        for _, tb in pairs(tabs) do tb.TextColor3 = Color3.fromRGB(150, 120, 130) end
        p.Visible = true; b.TextColor3 = cfg.accent
    end)
    tabs[name] = b; pages[name] = p; return p
end

local toggleButtons = {}
local function updateToggleVisual(var)
    if toggleButtons[var] then
        local b = toggleButtons[var].Btn; local txt = toggleButtons[var].Txt
        b.Text = txt .. ": " .. (cfg[var] and "ON" or "OFF")
        b.TextColor3 = cfg[var] and cfg.accent or cfg.text
        b.BackgroundColor3 = cfg[var] and Color3.fromRGB(255, 240, 245) or cfg.sec
    end
end

local function addToggle(p, txt, var)
    local b = Instance.new("TextButton", p); b.Size = UDim2.new(1, -5, 0, 35); b.BackgroundColor3 = cfg.sec
    b.Font = Enum.Font.GothamMedium; b.TextSize = 13; Instance.new("UICorner", b)
    local s = Instance.new("UIStroke", b); s.Color = cfg.accent; s.Transparency = 0.8
    toggleButtons[var] = {Btn = b, Txt = txt}; updateToggleVisual(var)
    b.MouseButton1Click:Connect(function() cfg[var] = not cfg[var]; updateToggleVisual(var); save() end)
end

local function addBind(p, txt, var)
    local b = Instance.new("TextButton", p); b.Size = UDim2.new(1, -5, 0, 30); b.BackgroundColor3 = Color3.fromRGB(245, 245, 245)
    b.Text = txt .. " Bind: [" .. cfg[var] .. "]"; b.TextColor3 = cfg.accent; b.Font = Enum.Font.GothamBold; b.TextSize = 12; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        b.Text = "..."; local connection; connection = UIS.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Keyboard then
                cfg[var] = input.KeyCode.Name; b.Text = txt .. " Bind: [" .. cfg[var] .. "]"; b.TextColor3 = cfg.accent; save(); connection:Disconnect()
            end
        end)
    end)
end

local function addInput(p, ph, var, min, max)
    local i = Instance.new("TextBox", p); i.Size = UDim2.new(1, -5, 0, 35); i.BackgroundColor3 = cfg.sec
    i.Text = tostring(cfg[var]); i.PlaceholderText = ph; i.TextColor3 = cfg.text; i.Font = Enum.Font.Gotham; Instance.new("UICorner", i)
    local s = Instance.new("UIStroke", i); s.Color = cfg.accent; s.Transparency = 0.9
    i.FocusLost:Connect(function() local val = tonumber(i.Text); if val then if min and max then val = math.clamp(val, min, max) end cfg[var] = val; save() end end)
end

