-- 5. LOGIC ENGINE (ALL FEATURES RESTORED)
local stickTarget = nil
local stickyTick = 0
local stickyCooldown = false

RunService.Heartbeat:Connect(function()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")

    -- PERSISTENT SPEED OVERWRITE
    if hum and cfg.speedOn then
        hum.WalkSpeed = tonumber(cfg.speedVal) or 16
    end

    if hrp then
        -- ORIGINAL STICKY LOGIC
        if cfg.stickyOn and not stickyCooldown then
            if not stickTarget then
                for _, op in pairs(game.Players:GetPlayers()) do
                    if op ~= player and op.Character and op.Character:FindFirstChild("Head") then
                        local head = op.Character.Head
                        if (hrp.Position - head.Position).Magnitude < 4 and hrp.Position.Y > head.Position.Y then
                            stickTarget = head; stickyTick = tick()
                        end
                    end
                end
            else
                local offset = Vector3.new(0, 2.7, 0)
                hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(stickTarget.Position + offset, stickTarget.Position + offset + hrp.CFrame.LookVector), cfg.stickySmooth)
                if tick() - stickyTick >= (tonumber(cfg.stickyMaxTime) or 0.3) then
                    stickTarget = nil; stickyCooldown = true
                    task.delay(0.7, function() stickyCooldown = false end)
                end
            end
        else stickTarget = nil end

        -- ORIGINAL HITBOX LOGIC
        for _, op in pairs(game.Players:GetPlayers()) do
            if op ~= player and op.Character and op.Character:FindFirstChild("Head") then
                local h = op.Character.Head
                if cfg.headOn then
                    h.Size = Vector3.new(cfg.headScl, cfg.headScl, cfg.headScl)
                    h.Transparency = cfg.headTrans or 0.5
                    h.CanCollide = true; h.Massless = true
                else
                    h.Size = Vector3.new(1.2, 1.2, 1.2); h.Transparency = 0
                end
            end
        end
    end

    if cfg.greyOn then
        for _, sky in pairs(Lighting:GetChildren()) do if sky:IsA("Sky") then sky:Destroy() end end
        Lighting.EnvironmentDiffuseScale = 0; Lighting.EnvironmentSpecularScale = 0
    end
    workspace.Gravity = cfg.gravOn and tonumber(cfg.gravVal) or 196.2
end)

-- AUTO CATCH SPAM (Original Restored)
task.spawn(function()
    while task.wait(0.05) do
        if cfg.autoCatchOn then
            local football = workspace:FindFirstChild("Football") or workspace:FindFirstChild("Ball")
            if football and player.Character and (player.Character.PrimaryPart.Position - football.Position).Magnitude < cfg.autoCatchRng then
                -- Simulate catch action based on original VLQMPS trigger
                fireclickdetector(football:FindFirstChildOfClass("ClickDetector"))
            end
        end
    end
end)

