local player = game.Players.LocalPlayer
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")

if player.PlayerGui:FindFirstChild("VLQMPS_V20") then
    player.PlayerGui.VLQMPS_V20:Destroy()
end

local success, err = pcall(function()
    ------------------------------------------------
    -- MASTER CONFIG
    local cfg = {
        uiVisible = true,
        -- Boost (Trampoline)
        boostOn = false,
        boostPwr = 100,
        -- Head
        headOn = false,
        headScl = 2.5,
        -- Catch
        catchOn = false,
        catchStr = 5,
        catchRng = 15,
        catchSpd = 0.15,
        -- Fling (Directional)
        flingOn = false,
        flingPwr = 125,
        flingKey = Enum.KeyCode.F,
        
        accent = Color3.fromRGB(0, 255, 150),
        bg = Color3.fromRGB(10, 10, 10),
        sec = Color3.fromRGB(25, 25, 25)
    }

    ------------------------------------------------
    -- UI FRAMEWORK
    local gui = Instance.new("ScreenGui", player.PlayerGui)
    gui.Name = "VLQMPS_V20"
    gui.ResetOnSpawn = false

    local main = Instance.new("Frame", gui)
    main.Size = UDim2.new(0, 480, 0, 380)
    main.Position = UDim2.new(0.5, -240, 0.5, -190)
    main.BackgroundColor3 = cfg.bg
    main.Active, main.Draggable = true, true
    Instance.new("UICorner", main)
    Instance.new("UIStroke", main).Color = cfg.accent

    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0, 120, 1, 0)
    sidebar.BackgroundColor3 = Color3.fromRGB(5, 5, 5)
    Instance.new("UICorner", sidebar)

    local container = Instance.new("Frame", main)
    container.Size = UDim2.new(1, -135, 1, -10)
    container.Position = UDim2.new(0, 130, 0, 5)
    container.BackgroundTransparency = 1

    local pages, tabs = {}, {}
    local function createTab(name, id)
        local btn = Instance.new("TextButton", sidebar)
        btn.Size = UDim2.new(1, 0, 0, 40)
        btn.BackgroundTransparency = 1
        btn.Text, btn.TextColor3 = name:upper(), Color3.fromRGB(130, 130, 130)
        btn.Font, btn.TextSize = Enum.Font.GothamBold, 11
        Instance.new("UIListLayout", sidebar).Padding = UDim.new(0, 2)

        local pg = Instance.new("ScrollingFrame", container)
        pg.Size, pg.BackgroundTransparency = UDim2.new(1, 0, 1, 0), 1
        pg.Visible, pg.ScrollBarThickness = false, 0
        pg.AutomaticCanvasSize = Enum.AutomaticSize.Y
        Instance.new("UIListLayout", pg).Padding = UDim.new(0, 8)

        btn.MouseButton1Click:Connect(function()
            for _, p in pairs(pages) do p.Visible = false end
            for _, t in pairs(tabs) do t.TextColor3 = Color3.fromRGB(130, 130, 130) end
            pg.Visible, btn.TextColor3 = true, cfg.accent
        end)
        tabs[id], pages[id] = btn, pg
        return pg
    end

    local function createToggle(parent, text, default, callback)
        local btn = Instance.new("TextButton", parent)
        btn.Size, btn.BackgroundColor3 = UDim2.new(1, -10, 0, 35), cfg.sec
        local state = default
        btn.Text = text .. ": " .. (state and "ON" or "OFF")
        btn.TextColor3 = state and cfg.accent or Color3.new(1,1,1)
        btn.Font = Enum.Font.Gotham
        Instance.new("UICorner", btn)
        btn.MouseButton1Click:Connect(function()
            state = not state
            btn.Text = text .. ": " .. (state and "ON" or "OFF")
            btn.TextColor3 = state and cfg.accent or Color3.new(1,1,1)
            callback(state)
        end)
    end

    local function createInput(parent, placeholder, callback)
        local box = Instance.new("TextBox", parent)
        box.Size, box.BackgroundColor3 = UDim2.new(1, -10, 0, 35), cfg.sec
        box.PlaceholderText, box.Text = placeholder, ""
        box.TextColor3, box.Font = Color3.new(1,1,1), Enum.Font.Gotham
        Instance.new("UICorner", box)
        box.FocusLost:Connect(function() callback(box.Text) end)
    end

    local p_boost = createTab("Boost", 1)
    local p_head  = createTab("Head", 2)
    local p_catch = createTab("Catch", 3)
    local p_fling = createTab("Fling", 4)
    local p_misc  = createTab("Misc", 5)
    pages[1].Visible, tabs[1].TextColor3 = true, cfg.accent

    ------------------------------------------------
    -- CORE LOGIC
    RunService.RenderStepped:Connect(function()
        local char = player.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end

        -- 1. TRAMPOLINE BOOST (Waist & Down Logic)
        if cfg.boostOn then
            for _, p in pairs(game.Players:GetPlayers()) do
                if p ~= player and p.Character and p.Character:FindFirstChild("Head") then
                    local targetHead = p.Character.Head
                    local dist = (root.Position - targetHead.Position).Magnitude
                    
                    -- Check if player is above the target head and within 4 studs
                    if dist < 4 and root.Position.Y > targetHead.Position.Y then
                        root.AssemblyLinearVelocity = Vector3.new(root.AssemblyLinearVelocity.X, cfg.boostPwr, root.AssemblyLinearVelocity.Z)
                    end
                end
            end
        end

        -- 2. HEAD SIZE
        local head = char:FindFirstChild("Head")
        if head then
            local mesh = head:FindFirstChildOfClass("SpecialMesh")
            if cfg.headOn then
                head.Size = Vector3.new(cfg.headScl, cfg.headScl, cfg.headScl)
                if mesh then mesh.Scale = Vector3.new(cfg.headScl, cfg.headScl, cfg.headScl) end
            else
                head.Size = Vector3.new(1.2, 1.2, 1.2)
                if mesh then mesh.Scale = Vector3.new(1, 1, 1) end
            end
        end

        -- 3. AUTO CATCH RESIZE
        local targetSize = Vector3.new(1,1,1)
        if cfg.catchOn then
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("BasePart") and (v.Name == "Football" or v.Name == "Ball") then
                    if (root.Position - v.Position).Magnitude < cfg.catchRng then
                        targetSize = Vector3.new(cfg.catchStr, cfg.catchStr, cfg.catchStr)
                    end
                end
            end
        end
        for _, n in pairs({"LeftHand", "RightHand", "LeftLowerArm", "RightLowerArm"}) do
            local p = char:FindFirstChild(n)
            if p then 
                p.Size = p.Size:Lerp(targetSize, cfg.catchSpd)
                p.CanCollide = false 
            end
        end
    end)

    ------------------------------------------------
    -- TAB CONTENT MAPPING
    createToggle(p_boost, "Trampoline Boost", false, function(v) cfg.boostOn = v end)
    createInput(p_boost, "Jump Power (100)", function(v) cfg.boostPwr = tonumber(v) or 100 end)

    createToggle(p_head, "Big Head", false, function(v) cfg.headOn = v end)
    createInput(p_head, "Size (2.5)", function(v) cfg.headScl = tonumber(v) or 2.5 end)

    createToggle(p_catch, "Auto Catch Resizer", false, function(v) cfg.catchOn = v end)
    createInput(p_catch, "Size (5)", function(v) cfg.catchStr = tonumber(v) or 5 end)
    createInput(p_catch, "Range (15)", function(v) cfg.catchRng = tonumber(v) or 15 end)

    createToggle(p_fling, "Fling Enabled", false, function(v) cfg.flingOn = v end)
    createInput(p_fling, "Fling Force (125)", function(v) cfg.flingPwr = tonumber(v) or 125 end)
    local fBtn = Instance.new("TextButton", p_fling)
    fBtn.Size, fBtn.BackgroundColor3 = UDim2.new(1, -10, 0, 35), cfg.sec
    fBtn.Text, fBtn.TextColor3, fBtn.Font = "Bind: " .. cfg.flingKey.Name, Color3.new(1,1,1), Enum.Font.Gotham
    Instance.new("UICorner", fBtn)
    local listen = false
    fBtn.MouseButton1Click:Connect(function() listen, fBtn.Text = true, "..." end)

    createToggle(p_misc, "Performance", false, function(v) Lighting.GlobalShadows = not v end)

    ------------------------------------------------
    -- MOVEMENT DIRECTIONAL FLING
    UIS.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == Enum.KeyCode.Insert or input.KeyCode == Enum.KeyCode.DPadLeft then
            cfg.uiVisible = not cfg.uiVisible
            main.Visible = cfg.uiVisible
        end
        if listen then
            cfg.flingKey = input.KeyCode
            fBtn.Text = "Bind: " .. input.KeyCode.Name
            listen = false
            return
        end
        
        -- MOVEMENT-BASED FLING LOGIC
        if input.KeyCode == cfg.flingKey and cfg.flingOn then
            local char = player.Character
            local hum = char and char:FindFirstChild("Humanoid")
            local r = char and char:FindFirstChild("HumanoidRootPart")
            if r and hum then
                -- Get MoveDirection (where the player is actually walking)
                local moveDir = hum.MoveDirection
                -- If standing still, use LookVector. If moving, use MoveDirection.
                local finalDir = moveDir.Magnitude > 0 and moveDir or r.CFrame.LookVector
                
                r.AssemblyLinearVelocity = finalDir * (cfg.flingPwr * 6)
            end
        end
    end)
end)
