-- 5. LOGIC ENGINE
local stickTarget = nil
local stickyTick = 0
local stickyCooldown = false

RunService.Heartbeat:Connect(function()
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if cfg.greyOn then
        for _, sky in pairs(Lighting:GetChildren()) do if sky:IsA("Sky") then sky:Destroy() end end
        Lighting.EnvironmentDiffuseScale = 0; Lighting.EnvironmentSpecularScale = 0
    end

    if cfg.infStaminaOn then
        local s = char:FindFirstChild("Stamina") or player:FindFirstChild("Stamina")
        if s and (s:IsA("NumberValue") or s:IsA("IntValue")) then s.Value = 100 end
        if char:GetAttribute("Stamina") then char:SetAttribute("Stamina", 100) end
    end

    if cfg.stickyOn and not stickyCooldown then
        if not stickTarget then
            for _, op in pairs(game.Players:GetPlayers()) do
                if op ~= player and op.Character and op.Character:FindFirstChild("Head") then
                    local head = op.Character.Head
                    if (hrp.Position - head.Position).Magnitude < 4 and hrp.Position.Y > head.Position.Y then
                        stickTarget = head; stickyTick = tick()
                    end
                end
            end
        else
            local offset = Vector3.new(0, 2.7, 0)
            hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(stickTarget.Position + offset, stickTarget.Position + offset + hrp.CFrame.LookVector), cfg.stickySmooth)
            if tick() - stickyTick >= (tonumber(cfg.stickyMaxTime) or 0.3) then
                stickTarget = nil; stickyCooldown = true
                task.delay(0.7, function() stickyCooldown = false end)
            end
        end
    else stickTarget = nil end

    for _, op in pairs(game.Players:GetPlayers()) do
        if op ~= player and op.Character and op.Character:FindFirstChild("Head") then
            local h = op.Character.Head
            if cfg.headOn then
                h.Size = Vector3.new(cfg.headScl, cfg.headScl, cfg.headScl)
                h.Transparency = cfg.headTrans
                h.CanCollide = true 
                h.CanTouch = true  
                h.Massless = true  
            else
                h.Size = Vector3.new(1.2, 1.2, 1.2)
                h.Transparency = 0
            end
        end
    end

    workspace.Gravity = cfg.gravOn and tonumber(cfg.gravVal) or 196.2
end)

UIS.InputBegan:Connect(function(i, gp)
    if gp then return end
    local key = i.KeyCode.Name
    if key == cfg.uiToggleKey then main.Visible = not main.Visible end
    
    if key == cfg.headBind then cfg.headOn = not cfg.headOn; updateToggleVisual("headOn") end
    if key == cfg.stickyBind then cfg.stickyOn = not cfg.stickyOn; updateToggleVisual("stickyOn") end
    if key == cfg.boostBind then cfg.boostOn = not cfg.boostOn; updateToggleVisual("boostOn") end
    if key == cfg.catchBind then cfg.autoCatchOn = not cfg.autoCatchOn; updateToggleVisual("autoCatchOn") end
    if key == cfg.gravBind then cfg.gravOn = not cfg.gravOn; updateToggleVisual("gravOn") end
    
    if key == cfg.flingBind and cfg.flingOn then
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.AssemblyLinearVelocity = hrp.CFrame.LookVector * (tonumber(cfg.flingPwr) or 125) end
    end
end)
