UIS.InputBegan:Connect(function(i, gp)
    if gp then return end
    local key = i.KeyCode.Name
    if key == cfg.uiToggleKey then main.Visible = not main.Visible end
    if key == cfg.headBind then cfg.headOn = not cfg.headOn; updateToggleVisual("headOn") end
    if key == cfg.stickyBind then cfg.stickyOn = not cfg.stickyOn; updateToggleVisual("stickyOn") end
    if key == cfg.speedBind then cfg.speedOn = not cfg.speedOn; updateToggleVisual("speedOn") end
    if key == cfg.flingBind and cfg.flingOn then
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.AssemblyLinearVelocity = hrp.CFrame.LookVector * (tonumber(cfg.flingPwr) or 125) end
    end
end)
